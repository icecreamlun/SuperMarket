# Notion internal integration token.
# Create one at https://www.notion.so/profile/integrations/internal,
# share the Intake DB with this integration, then paste the secret here.
NOTION_API_TOKEN=

# The Notion database ID where new inbound rows are created.
# Open the Intake DB → ... → Copy link → take the 32-char hex id.
# (NOTION_* prefix is reserved by the platform — only NOTION_API_TOKEN is whitelisted.)
INTAKE_DATABASE_ID=

# Shared secret you set on the GitHub repo webhook (Settings → Webhooks).
GITHUB_WEBHOOK_SECRET=

# Optional GitHub PAT (read:user, public_repo) used for enrichment.
# Without it we still work on public profiles but get rate-limited at 60/hr.
GITHUB_TOKEN=

# Anthropic API key for the triage LLM call.
# If unset, we fall back to a low-confidence heuristic so the pipeline still runs.
ANTHROPIC_API_KEY=

# Apify token (Tweet Scraper V2 apidojo~tweet-scraper).
APIFY_API_TOKEN=

# X / Twitter handle of the user being represented (no @ prefix).
# Tweets authored by this handle are skipped (no self-triage).
X_OWN_HANDLE=

# Comma-separated brand keywords to monitor on X.
# Be specific — single-word brand names (e.g. "minimax") collide with
# unrelated content. Prefer multi-word phrases.
X_BRAND_KEYWORDS=
