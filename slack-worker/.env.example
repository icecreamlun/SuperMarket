# Slack worker environment template.
# Copy to `.env` and fill in real values. `.env` is gitignored.
# For the deployed worker, push with `ntn workers env push` or set
# individual values via `ntn workers env set KEY=VALUE`.

# ---- Slack ----
# From your Slack app: Settings → Basic Information → Signing Secret.
# Used to verify Slack signatures on /triage and message-action requests.
SLACK_SIGNING_SECRET=

# ---- Notion ----
# Internal integration token from https://www.notion.so/profile/integrations
# Must be installed in the workspace that owns the Opportunities database
# and shared with the destination page/database.
NOTION_API_TOKEN=

# Notion database ID where each triage row is created (Opportunities).
# Strip dashes or keep them — both accepted.
OPPORTUNITIES_DATABASE_ID=

# ---- Cortex Areas row IDs ----
# Page (row) IDs in the Cortex "Areas" database, one per source channel.
# The worker sets the Source Channel relation on each new Opportunity
# so the dashboard rollups (Total / High Priority / Completed) update.
AREA_GMAIL_ID=
AREA_SLACK_ID=
AREA_X_ID=
AREA_GITHUB_ID=
